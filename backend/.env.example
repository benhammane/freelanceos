# Database (Railway PostgreSQL will inject these automatically)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/freelanceos
SPRING_DATASOURCE_USERNAME=freelanceos
SPRING_DATASOURCE_PASSWORD=freelanceos
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT Configuration
APP_JWT_SECRET=your-secret-jwt-key-change-in-production-at-least-32-characters
APP_JWT_EXPIRATION_MS=86400000

# Admin Account (created on first startup)
APP_ADMIN_EMAIL=admin@freelanceos.local
APP_ADMIN_PASSWORD=ChangeMe123!

# Stripe Configuration (https://dashboard.stripe.com)
APP_STRIPE_SECRET_KEY=sk_test_your_test_secret_key
APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key

# Server Configuration
SERVER_PORT=8080
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false
